# wh11ed-api — environment variables.
# In production these are injected by Yandex Lockbox (see infra/). NEVER commit real secrets.
# Copy to .env for local development (`npm run dev`).

# --- App ---
# Comma-separated list of allowed CORS origins (the SPA origins).
ALLOWED_ORIGINS=http://localhost:5173,https://wh11ed.ru
# Public base URL of THIS api (used to build OAuth redirect URIs).
API_BASE_URL=http://localhost:8787
# Where to send the browser back to after a successful login (a thin SPA route).
APP_AFTER_LOGIN_URL=http://localhost:5173/#/tracker/auth-callback
# Cookie Domain for the refresh cookie. Leave empty for localhost; set api.wh11ed.ru in prod.
COOKIE_DOMAIN=

# --- Session / JWT ---
# 32+ byte random string. Generate: openssl rand -base64 48
JWT_SIGNING_KEY=dev-only-insecure-key-change-me-0000000000000000
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# --- OAuth: Google ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- OAuth: Yandex ---
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# --- YDB ---
# Serverless endpoint + database path from the YDB console.
YDB_ENDPOINT=grpcs://ydb.serverless.yandexcloud.net:2135
YDB_DATABASE=/ru-central1/b1xxxx/etnxxxx
# Local dev auth: paste an IAM token (`yc iam create-token`). In YCF this is unset and the
# function uses metadata (service-account) auth automatically.
YDB_ACCESS_TOKEN=
